# ──────────────────────────────────────────────
#  frontend/.env.example
#  Copy this file to .env and fill in real values
#  NEVER commit the real .env file to GitHub
# ──────────────────────────────────────────────

# Backend API URL
# - Leave EMPTY for local dev (Vite proxy will forward /api → http://localhost:5000)
# - Set to your Render URL for production builds
# Example: VITE_API_URL=https://farmdirect-api.onrender.com
VITE_API_URL=
